---
import site from '../data/site.json';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 px-6 py-6 sm:flex-row sm:items-center">
    <a href="/" class="text-2xl font-bold tracking-tight text-indigo-700 hover:text-indigo-900">
      {site.title}
    </a>
    <nav class="flex flex-wrap gap-4 text-sm font-medium">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'hover:text-indigo-700',
              isActive(item.href) ? 'text-indigo-700' : 'text-slate-600',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
