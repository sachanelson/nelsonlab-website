---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout title="Home">
  <section class="py-16 text-center">
    <h1 class="mb-4 text-5xl font-extrabold text-slate-900">{site.title}</h1>
    <p class="text-2xl text-slate-600">{site.tagline}</p>
    <p class="mt-6 text-slate-500">{site.institution}</p>
  </section>
</Layout>
